# 服务器配置
NODE_ENV=production
PORT=3000

# 数据库配置（Docker 内部使用 mongodb 服务名）
MONGODB_URI=mongodb://mongodb:27017/mbri-website

# JWT 配置（请修改为安全的密钥）
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# 管理员账号（请修改密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$yYmWNHS5KwW4JpBIbxjKE.Yv9D8bRwraWWGvgdDP6gV8A2LO6itfG

# CORS（Docker 内部 Nginx 反代，不需要）
ENABLE_CORS=false
